# Embedding server (OpenAI-compatible)
NEWSSTACK_EMBEDDING_URL=http://localhost:9097/v1/embeddings
NEWSSTACK_EMBEDDING_MODEL=nomic-embed-text-v1.5
NEWSSTACK_EMBEDDING_DIM=768

# LLM server (OpenAI-compatible)
NEWSSTACK_LLM_URL=http://localhost:9096/v1/chat/completions
NEWSSTACK_LLM_MODEL=qwen3.5

# Qdrant
NEWSSTACK_QDRANT_URL=http://localhost:6333

# SQLite
NEWSSTACK_DB_PATH=newsstack.db

# Server
NEWSSTACK_HOST=0.0.0.0
NEWSSTACK_PORT=8080

# Data retention (days)
NEWSSTACK_RETENTION_DAYS=180
